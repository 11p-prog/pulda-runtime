modules = ["python-3.11", "nodejs-24", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pulda.app"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
AUTO_SYNC_NOTION = "false"
NOTION_SYNC_PAGE_ID = "39be35ff-69e0-81f5-b7f1-fccd826d47a7"
AUTO_INGEST_DAILY_ACTIVITY_QUEUE = "true"
NOTION_DAILY_ACTIVITY_QUEUE_PAGE_ID = "3a2e35ff-69e0-81ea-8eb9-ed63a333e962"
DAILY_ACTIVITY_PULL_HOUR = "22"
DAILY_ACTIVITY_PULL_MINUTE = "40"
AUTO_SYNC_GITHUB = "false"
GITHUB_BRANCH = "main"
GITHUB_REPOSITORY = "11p-prog/pulda-runtime"
PULDA_HOST = "0.0.0.0"
PULDA_PORT = "5000"

[deployment]
deploymentTarget = "cloudrun"
run = ["python", "-m", "pulda.app"]
